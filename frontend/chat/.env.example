# Backend (FastAPI) base URL used by the Vite dev proxy.
# All /api requests in the browser are forwarded here.
VITE_BACKEND_URL=http://localhost:8000

# Optional: hard-coded fallback Agent Server URL.
# Normally the URL comes from the /run-bundle response, so leave this blank
# unless you want to override it for local debugging.
# VITE_AGENT_SERVER_URL=http://localhost:2024
