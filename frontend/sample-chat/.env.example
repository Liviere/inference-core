# Backend (FastAPI) base URL used by the Vite dev proxy.
# All /api requests in the browser are forwarded here.
VITE_BACKEND_URL=http://localhost:8000

# LangGraph Agent Server URL used by the /api/langgraph dev proxy.
# Leave the default unless you run Agent Server on a different host/port.
VITE_AGENT_SERVER_URL=http://127.0.0.1:2024

# If "true", ChatView rewrites bundle.agent_server_url to same-origin
# (${window.location.origin}/api/langgraph) so the browser never talks
# to the Agent Server cross-origin — handy for local dev.
VITE_USE_AGENT_PROXY=true
