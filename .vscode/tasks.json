{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run FastAPI Server",
			"type": "shell",
			"command": "poetry run python run.py",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Run FastAPI Development Server (Poetry)",
			"type": "shell",
			"command": "poetry run uvicorn inference_core.main_factory:create_application --factory --reload --host 0.0.0.0 --port 8000",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Celery: Start Worker",
			"type": "shell",
			"command": "poetry run celery -A inference_core.celery.celery_main:celery_app worker -n worker@%h --pool=threads --exclude-queues=embeddings,mail --loglevel=info",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Celery: Start Worker (Mail)",
			"type": "shell",
			"command": "poetry run celery -A inference_core.celery.celery_main:celery_app worker -n mail@%h --queues=mail --pool=threads --loglevel=info",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Celery: Start Worker (Embeddings)",
			"type": "shell",
			"command": "poetry run celery -A inference_core.celery.celery_main:celery_app worker -n embeddings@%h --queues=embeddings --pool=solo --loglevel=info",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Celery: Start Beat",
			"type": "shell",
			"command": "poetry run celery -A inference_core.celery.celery_main:celery_app beat --loglevel=info",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "Celery: Start Worker (DEBUG)",
			"type": "shell",
			"command": "export DEBUG_CELERY=1 && poetry run celery -A inference_core.celery.celery_main:celery_app worker -n debug@%h --loglevel=info",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "LangGraph: Dev Server",
			"type": "shell",
			"command": "poetry run langgraph dev --no-browser",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "LangGraph: Dev Server (with debugger)",
			"type": "shell",
			"command": "poetry run langgraph dev --no-browser --debug-port 5679",
			"group": "build",
			"isBackground": true,
			"problemMatcher": []
		}
	]
}
